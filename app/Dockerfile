# 1. שימוש בתמונת בסיס רשמית ורזה (Slim) כדי להקטין את גודל התמונה ושטח התקיפה האפשרי
FROM python:3.11-slim

# 2. הגדרת משתני סביבה: מניעת כתיבת קבצי קאש של פייתון, ודאגה שהלוגים יודפסו ישירות לטרמינל
ENV PYTHONDONTWRITEBYTECODE=1
ENV PYTHONUNBUFFERED=1

# 3. פרקטיקת אבטחה: יצירת משתמש "רגיל" (Non-root user) כדי שהאפליקציה לא תרוץ עם הרשאות מנהל
RUN addgroup --system appgroup && adduser --system --group appuser

# 4. הגדרת תיקיית העבודה בתוך הקונטיינר
WORKDIR /app

# 5. אופטימיזציה של בנייה: העתקת קובץ הדרישות בלבד לפני שאר הקוד כדי לנצל את מנגנון המטמון (Cache) של דוקר
COPY requirements.txt .

# 6. התקנת חבילות פייתון ללא שמירת מטמון ההתקנה של pip כדי לשמור על קונטיינר קטן
RUN pip install --no-cache-dir -r requirements.txt

# 7. העתקת שאר קוד האפליקציה לתוך הקונטיינר
COPY . .

# 8. העברת הבעלות על קבצי האפליקציה למשתמש הלא-מורשה שיצרנו
RUN chown -R appuser:appgroup /app

# 9. החלפת המשתמש הפעיל למשתמש הלא-מורשה
USER appuser

# 10. הצהרה על הפורט שהאפליקציה מאזינה לו (למשל 8000, עליך לעדכן זאת בהתאם לקוד שקיבלת)
EXPOSE 8000

# 11. פקודת ההרצה של האפליקציה (כאן הנחתי שהקובץ הראשי נקרא main.py)
CMD ["python", "main.py"]